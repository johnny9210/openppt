# =============================================
# PPT Code Generation - Environment Variables
# =============================================
# Copy to .env and fill in actual values

# AWS Bedrock (Claude)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Azure OpenAI (GPT)
APIM_AOAI_ENDPOINT=https://your-apim-endpoint.azure-api.net
APIM_AOAI_API_KEY=your_aoai_api_key

# LLM Settings
DEFAULT_LLM=claude
GPT_DEPLOYMENT=gpt-4o
GPT_API_VERSION=2025-01-01-preview
CLAUDE_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# Google AI Studio (Nano Banana - Gemini Image Generation)
GOOGLE_AI_STUDIO_KEY=your_google_ai_studio_key
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# Pipeline Settings
MAX_REVISIONS=3
TEMPERATURE=0

# Service URLs (Docker internal)
VALIDATOR_URL=http://validator:8001
CORE_API_URL=http://core:8000
NEXT_PUBLIC_API_URL=http://localhost:8030
